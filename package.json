{
  "name": "hago-produce",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "seed": "ts-node --project tsconfig.seed.json prisma/seed.ts"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest --testPathIgnorePatterns=integration",
    "test:integration:setup": "docker-compose -f docker-compose.test.yml up -d --wait",
    "test:integration:teardown": "docker-compose -f docker-compose.test.yml down -v",
    "test:integration:db-push": "dotenv -e .env.test -- npx prisma db push --skip-generate",
    "test:integration:generate": "npx prisma generate",
    "test:integration:run": "dotenv -e .env.test -- jest -c jest.integration.config.js --forceExit --runInBand",
    "test:integration": "npm run test:integration:setup && npm run test:integration:db-push && npm run test:integration:generate && npm run test:integration:run",
    "test:all": "npm run test && npm run test:integration",
    "test:e2e": "playwright test",
    "seed:staging": "ts-node --project tsconfig.seed.json prisma/seed-staging.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^5.10.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@sendgrid/mail": "^8.1.6",
    "@sentry/node": "^10.40.0",
    "@sentry/profiling-node": "^10.40.0",
    "bcrypt": "^6.0.0",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.0",
    "cmdk": "^1.1.1",
    "csv-stringify": "^6.6.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "googleapis": "^140.0.0",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "jszip": "^3.10.1",
    "lucide-react": "^0.344.0",
    "next": "14.1.0",
    "next-auth": "^5.0.0-beta.15",
    "node-telegram-bot-api": "^0.67.0",
    "openai": "^6.24.0",
    "pdf-parse": "^2.4.5",
    "react": "^18",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18",
    "react-hook-form": "^7.71.1",
    "recharts": "^3.7.0",
    "resend": "^3.5.0",
    "tailwind-merge": "^2.2.1",
    "tsx": "^4.21.0",
    "twilio": "^5.12.2",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcrypt": "^6.0.0",
    "@types/chart.js": "^2.9.41",
    "@types/jest": "^29.5.12",
