# ============================================
# HAGO PRODUCE - Environment Variables
# ============================================

# App
NODE_ENV=development
APP_URL=http://localhost:3000

# Database (Railway PostgreSQL)
# Format: postgresql://user:password@host:port/db
DATABASE_URL=postgresql://user:pass@host:port/db

# Auth (NextAuth.js)
NEXTAUTH_SECRET=your-32-char-secret-here
NEXTAUTH_URL=http://localhost:3000
JWT_SECRET=your-jwt-secret-here

# AI - OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Twilio - WhatsApp Business
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=+14155238886
TWILIO_WEBHOOK_URL=https://your-domain.com/api/v1/bot/webhook/whatsapp
TWILIO_SANDBOX_MODE=true
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Notifications Webhook (para enviar WhatsApp/Telegram desde backend)
NOTIFICATIONS_WEBHOOK_URL=http://localhost:3000/webhooks/notifications/send

# Make.com Integration
MAKE_WEBHOOK_API_KEY=hk_prod_xxxxxxxxxxxxxxxx
WEBHOOK_RATE_LIMIT=100

# Chat Configuration
CHAT_RATE_LIMIT=20

# Cron Jobs
CRON_SECRET=your-cron-secret-here

# Railway
RAILWAY_TOKEN=your-token
RAILWAY_PROJECT_ID=your-project-id
